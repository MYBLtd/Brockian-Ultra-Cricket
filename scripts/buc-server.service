[Unit]
Description=Sensor Panel UX Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/fs01/sensor_panel_ux-server
EnvironmentFile=/etc/default/sensor-panel-ux-server
ExecStart=/fs01/sensor_panel_ux-server/bin/sensor-panel-ux-server
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
